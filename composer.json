{
    "name": "syedmahroof/laravel-ai-pulse",
    "description": "AI Pulse — observability, analytics, and a developer playground for the Laravel AI SDK.",
    "keywords": [
        "laravel",
        "ai",
        "pulse",
        "observability",
        "agent",
        "playground",
        "audit",
        "analytics",
        "debugging",
        "export",
        "prompts",
        "pricing",
        "monitoring"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Syed Mahroof",
            "email": "mahroof917@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0|^13.0",
        "laravel/ai": "^0.8.1",
        "livewire/livewire": "^4.3"
    },
    "require-dev": {
        "larastan/larastan": "^3.10",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^11.1.0",
        "pestphp/pest": "^4.7"
    },
    "autoload": {
        "psr-4": {
            "Syedmahroof\\AiPulse\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Syedmahroof\\AiPulse\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Syedmahroof\\AiPulse\\AiPulseServiceProvider"
            ]
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "lint": "pint",
        "test": "pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
